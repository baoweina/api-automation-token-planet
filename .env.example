# 复制为 .env 后填写，.env 不会被提交到 git

# 测试环境网关地址
BASE_URL=https://test.tokenplanet.ai/app

# 人工完成一次 Google 三方登录后，从浏览器抓取的后端 Bearer Token
# 获取方式见 README「Token 获取与刷新」章节
AUTH_TOKEN=

# 人工完成一次 Google OAuth 授权后拿到的原始 thirdAuthToken（Google id_token）
# 专用于验证 THIRD_AUTH(Google) 登录场景本身，有效期很短，需要每次运行前人工刷新
GOOGLE_THIRD_AUTH_TOKEN=
# 换成你自己用来做 Google 登录测试的账号邮箱
GOOGLE_LOGIN_USERNAME=your-google-test-account@gmail.com

# 测试环境数据库（用于从 nw_app_mail 表读取邮箱动态验证码，仅本地 .env，不提交 git）
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=nativewallet

# 可选，一般不需要修改
CONTENT_LANGUAGE=zh_CN
DEVICE_TYPE=PC
CLIENT_TYPE=PC
USER_TYPE=APP
REQUEST_TIMEOUT=15
